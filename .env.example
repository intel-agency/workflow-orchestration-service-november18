# ============================================================================
# Local Orchestration Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Then source it before running scripts:
#   set -a; source .env; set +a
#
# Or use the setup helper:
#   bash scripts/setup-local-env.sh
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Orchestration will not start without these
# ---------------------------------------------------------------------------

# GitHub Personal Access Token (org-level PAT)
# Required scopes: repo, workflow, project, read:org
# Used by: gh CLI, opencode MCP GitHub server, orchestrator agent
GH_ORCHESTRATION_AGENT_TOKEN=

# ZhipuAI API key — access to GLM models (primary model provider)
ZHIPU_API_KEY=

# Kimi / Moonshot API key — backup model provider
KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Additional model providers
# ---------------------------------------------------------------------------

# OpenAI API key (GPT models)
# OPENAI_API_KEY=

# Google Gemini API key (mapped to GOOGLE_GENERATIVE_AI_API_KEY in container)
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Server configuration (defaults shown)
# ---------------------------------------------------------------------------

# Bind address for opencode serve (0.0.0.0 = all interfaces)
# OPENCODE_SERVER_HOSTNAME=0.0.0.0

# Listen port for opencode serve
# OPENCODE_SERVER_PORT=4096

# ---------------------------------------------------------------------------
# OPTIONAL — Server authentication (for LAN access)
# ---------------------------------------------------------------------------

# Basic auth credentials — when set, clients must include these in attach URLs
# OPENCODE_SERVER_USERNAME=
# OPENCODE_SERVER_PASSWORD=

# ============================================================================
# Python Client Service (ServiceConfig) — workflow-orchestration-client
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Client will not start without these
# ---------------------------------------------------------------------------

# GitHub org to monitor for orchestration events
GITHUB_ORG=

# HMAC secret configured on the org-wide GitHub webhook
WEBHOOK_SECRET=

# (GH_ORCHESTRATION_AGENT_TOKEN is already listed above and shared)

# ---------------------------------------------------------------------------
# OPTIONAL — Client runtime settings (defaults shown)
# ---------------------------------------------------------------------------

# URL for the opencode server's --attach endpoint
# OPENCODE_SERVER_URL=http://server:4096

# Sentinel polling interval in seconds
# POLL_INTERVAL_SECS=60

# Root directory where per-issue git worktrees are created
# GIT_REPOS_ROOT=./git_repos

# Path to the orchestrator prompt template (baked into prebuild image)
# PROMPT_TEMPLATE_PATH=/opt/orchestration/prompts/orchestrator-agent-prompt.md

# Hard timeout for opencode subprocess dispatches (seconds; 5700 = 95 min)
# SUBPROCESS_TIMEOUT_SECS=5700

# Comma-separated glob patterns for eligible repo name matching (empty = all)
# ELIGIBLE_REPO_PATTERNS=

# Directory/file whose presence in a repo marks it as orchestration-eligible
# ELIGIBILITY_MARKER_PATH=plan_docs

# Template repo name used for template-origin eligibility checking
# ORCHESTRATION_TEMPLATE_REPO=workflow-orchestration-service-november18
